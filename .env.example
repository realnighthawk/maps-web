VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Optional Map ID for Advanced Markers (defaults to DEMO_MAP_ID for dev).
# VITE_GOOGLE_MAPS_MAP_ID=

# Production / split-origin (e.g. GitHub Pages): public maps-engine URL (scheme + host, no path).
# VITE_MAPS_ENGINE_ORIGIN=https://maps-api.example.com
# GitHub project Pages asset path (must match repo Pages URL). Example: /my-repo/
# VITE_BASE_PATH=/

# Dev only: where `yarn dev` proxies `/api/*` (maps-engine). Default http://127.0.0.1:8080
# If something else already listens on 8080 (you may see API errors like "invalid or missing bearer token"),
# run maps-engine on another port (see maps-engine MAPS_ENGINE_HTTP_PORT) and set this to match.
MAPS_ENGINE_PROXY_TARGET=http://127.0.0.1:8181
